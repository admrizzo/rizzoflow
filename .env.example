# Exemplo de variáveis de ambiente — Rizzo Flow
#
# IMPORTANTE:
# - O arquivo `.env` real é gerado e mantido AUTOMATICAMENTE pelo Lovable Cloud.
#   Não edite `.env` manualmente.
# - Os valores abaixo são apenas referência de estrutura.
# - As chaves listadas aqui são "publishable" (anon key + URL pública do projeto),
#   seguras para uso no frontend. Nunca coloque service_role ou secrets privados aqui.
# - Secrets privados (API keys de terceiros, tokens etc.) devem ser cadastrados
#   em Lovable Cloud → Secrets e consumidos via Edge Functions.

VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-publishable-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"